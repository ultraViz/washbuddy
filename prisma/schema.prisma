generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Business {
  id        String      @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  users     User[]
  services  Service[]
  queue     QueueItem[]
  agents    Agent[]
  createdAt DateTime    @default(now())
}

model User {
  id         String    @id @default(cuid())
  name       String?
  email      String?   @unique
  password   String?
  role       String    @default("USER")
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  createdAt  DateTime  @default(now())
}

// Role enum converted to String
// SUPER_ADMIN, ADMIN, AGENT, USER

model Service {
  id         String      @id @default(cuid())
  name       String
  price      Float
  businessId String
  business   Business    @relation(fields: [businessId], references: [id])
  queueItems QueueItem[]
}

model Agent {
  id         String      @id @default(cuid())
  name       String
  phone      String?
  businessId String
  business   Business    @relation(fields: [businessId], references: [id])
  queueItems QueueItem[]
}

model Vehicle {
  id           String      @id @default(cuid())
  licensePlate String      @unique
  ownerName    String?
  ownerPhone   String?
  vehicleType  String?
  visits       QueueItem[]
}

model QueueItem {
  id            String         @id @default(cuid())
  status        String         @default("IN_QUEUE")
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id])
  vehicleId     String
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id])
  serviceId     String
  service       Service        @relation(fields: [serviceId], references: [id])
  agentId       String?
  agent         Agent?         @relation(fields: [agentId], references: [id])
  extraServices String?
  totalAmount   Float?
  paymentMethod String?
  checkInAt     DateTime       @default(now())
  completedAt   DateTime?
}

// QueueStatus and PaymentMethod enums converted to String
// QueueStatus: IN_QUEUE, WASH_BAY, FINISHING_BAY, COMPLETED
// PaymentMethod: CASH, CARD
